        "jsCode": "const folders = $input.first().json.value || [];\nconst folderMap = {};\nfolders.forEach(function(f) {\n  folderMap[f.displayName] = f.id;\n});\nconst categories = $('Parse Categories').first().json.categories;\nconst promptFragment = $('Parse Categories').first().json.promptFragment;\nreturn [{ json: { folderMap: folderMap, categories: categories, promptFragment: promptFragment } }];"
