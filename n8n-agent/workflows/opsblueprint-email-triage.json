    {
      "parameters": {
        "jsCode": "const moveResult = $('Move Email to Folder').first().json;\nconst classification = $('Parse Classification').first().json;\n\nreturn [{ json: {\n  emailId: moveResult.id,\n  subject: classification.subject,\n  senderEmail: classification.senderEmail,\n  category: classification.category,\n  confidence: classification.confidence,\n  reason: classification.reason,\n  folderName: classification.folderName,\n  status: 'triaged'\n} }];"
