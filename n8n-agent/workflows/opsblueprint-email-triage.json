    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst bodyText = (d.bodyPreview || '').substring(0, 2000);\nconst attachText = d.attachmentSummary || 'No attachments';\nconst promptFrag = d.promptFragment || '';\n\nconst systemPrompt = `You are an email classification assistant for OpsBlueprint, a workflow automation consulting firm.\n\nClassify the following email into exactly ONE of the provided categories. These categories are specific to an automation consulting business.\n\nRespond with JSON only:\n{\"category\": \"<exact category name>\", \"confidence\": <0.0-1.0>, \"reason\": \"<brief explanation>\"}\n\nIf your confidence is below 0.7, use \"Uncategorized\" as the category.\n\nCATEGORIES:\n${promptFrag}`;\n\nconst userPrompt = `EMAIL:\nFrom: ${d.senderName} <${d.senderEmail}>\nSubject: ${d.subject}\nReceived: ${d.receivedDateTime}\nBody:\n${bodyText}\n\nATTACHMENT SUMMARIES:\n${attachText}`;\n\nconst body = {\n  messages: [\n    { role: 'system', content: systemPrompt },\n    { role: 'user', content: userPrompt }\n  ],\n  max_completion_tokens: 500,\n  response_format: { type: 'json_object' }\n};\n\nreturn [{ json: { ...d, aiRequestBody: JSON.stringify(body) } }];"
      },
      "id": "node-build-ai",
      "name": "Build AI Classification Body",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4420, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('Setup Variables').first().json.aoaiEndpoint }}/openai/deployments/{{ $('Setup Variables').first().json.aoaiDeployment }}/chat/completions?api-version={{ $('Setup Variables').first().json.aoaiApiVersion }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.aiRequestBody }}",
        "options": {}
      },
      "id": "node-ai-classify",
      "name": "AI Classify Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [4680, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "0sfAlhodWZDgWdu5",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const aiResp = $input.first().json;\nconst emailData = $('Build AI Classification Body').first().json;\n\nlet category = 'Uncategorized';\nlet confidence = 0;\nlet reason = 'AI parsing failed';\n\ntry {\n  const content = aiResp.choices[0].message.content;\n  const parsed = JSON.parse(content);\n  category = parsed.category || 'Uncategorized';\n  confidence = parsed.confidence || 0;\n  reason = parsed.reason || '';\n} catch (e) {\n  // Keep defaults\n}\n\nif (confidence < 0.7) {\n  category = 'Uncategorized';\n}\n\n// Resolve folder name from categories table\nlet folderName = category;\nconst cats = emailData.categories || [];\nfor (let i = 0; i < cats.length; i++) {\n  if (cats[i].name === category) {\n    folderName = cats[i].folderName || category;\n    break;\n  }\n}\n\nconst folderMap = emailData.folderMap || {};\nconst folderId = folderMap[folderName] || null;\n\nreturn [{ json: {\n  emailId: emailData.emailId,\n  subject: emailData.subject,\n  senderEmail: emailData.senderEmail,\n  category: category,\n  confidence: confidence,\n  reason: reason,\n  folderName: folderName,\n  folderId: folderId,\n  needsNewFolder: !folderId,\n  folderMap: folderMap\n} }];"
      },
