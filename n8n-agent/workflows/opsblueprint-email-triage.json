    {
      "parameters": {
        "jsCode": "const rows = $input.first().json.value || [];\nconst categories = rows.map(function(r) {\n  const vals = r.values[0] || r.values;\n  return { name: vals[0], description: vals[1], folderName: vals[2] };\n});\n\n// Build prompt fragment listing all categories for AI\nlet promptFragment = categories.map(function(c) {\n  return '- ' + c.name + ': ' + c.description;\n}).join('\\n');\npromptFragment += '\\n- Uncategorized: Default for emails that do not clearly fit other categories';\n\nreturn [{ json: { categories: categories, promptFragment: promptFragment } }];"
      },
