    {
      "parameters": {
        "jsCode": "const emails = $input.first().json.value;\nconst folderMap = $('Build Folder Map').first().json.folderMap;\nconst categories = $('Build Folder Map').first().json.categories;\nconst promptFragment = $('Build Folder Map').first().json.promptFragment;\n\nreturn emails.map(function(e) {\n  return { json: {\n    emailId: e.id,\n    subject: e.subject || '(no subject)',\n    senderEmail: e.from && e.from.emailAddress ? e.from.emailAddress.address : 'unknown',\n    senderName: e.from && e.from.emailAddress ? e.from.emailAddress.name : 'unknown',\n    bodyPreview: e.bodyPreview || '',\n    hasAttachments: e.hasAttachments || false,\n    receivedDateTime: e.receivedDateTime || '',\n    folderMap: folderMap,\n    categories: categories,\n    promptFragment: promptFragment\n  }};\n});"
      },
