    {
      "parameters": {
        "jsCode": "const foldersResp = $input.first().json;\nconst prev = $('Parse Classification').first().json;\nconst folders = foldersResp.value || [];\n\nlet folderId = null;\nfor (let i = 0; i < folders.length; i++) {\n  if (folders[i].displayName === prev.folderName) {\n    folderId = folders[i].id;\n    break;\n  }\n}\n\nreturn [{ json: { ...prev, folderId: folderId } }];"
