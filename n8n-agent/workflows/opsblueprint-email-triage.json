    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst prev = $('Parse Classification').first().json;\n\n// If folder was created successfully, use its ID\nif (resp.id && resp.displayName) {\n  return [{ json: { ...prev, folderId: resp.id, needsNewFolder: false, folderLookupNeeded: false } }];\n}\n// If creation failed (e.g. folder already exists), we need to look it up\nreturn [{ json: { ...prev, folderId: null, needsNewFolder: false, folderLookupNeeded: true } }];"
      },
