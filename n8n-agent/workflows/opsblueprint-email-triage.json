      "position": [3120, 200]
    },
    {
      "parameters": {
        "jsCode": "const attachmentsResp = $input.first().json;\nconst emailData = $('Loop Over Emails').first().json;\nconst attachments = (attachmentsResp.value || []).filter(function(a) {\n  if (!a.name) return false;\n  const ext = a.name.split('.').pop().toLowerCase();\n  return ['pdf', 'docx', 'doc', 'xlsx', 'xls', 'csv', 'txt'].indexOf(ext) >= 0;\n}).map(function(a) {\n  return { name: a.name, contentType: a.contentType || '', contentBytes: a.contentBytes || '' };\n});\n\nif (attachments.length === 0) {\n  return [{ json: { ...emailData, attachmentSummary: '' } }];\n}\nreturn [{ json: { ...emailData, attachmentsForExtraction: attachments } }];"
      },
