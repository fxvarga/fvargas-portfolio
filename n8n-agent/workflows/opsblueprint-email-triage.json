      "parameters": {
        "jsCode": "const upn = $env.MAIL_USER_UPN;\nconst driveId = $env.SHAREPOINT_DRIVE_ID;\nconst categoriesFileId = $env.OB_EMAIL_CATEGORIES_FILE_ID;\nconst categoriesTableName = $env.OB_EMAIL_CATEGORIES_TABLE_NAME || 'OBCategories';\nconst tenantId = $env.MS_GRAPH_TENANT_ID;\nconst clientId = $env.MS_GRAPH_CLIENT_ID;\nconst clientSecret = $env.MS_GRAPH_CLIENT_SECRET;\nconst aoaiEndpoint = $env.AZURE_OPENAI_ENDPOINT;\nconst aoaiDeployment = $env.AZURE_OPENAI_CHAT_DEPLOYMENT;\nconst aoaiApiVersion = $env.AZURE_OPENAI_API_VERSION;\n\nreturn [{\n  json: {\n    upn, driveId, categoriesFileId, categoriesTableName,\n    tenantId, clientId, clientSecret,\n    aoaiEndpoint, aoaiDeployment, aoaiApiVersion\n  }\n}];"
      },
