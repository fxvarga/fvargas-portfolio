# DigitalOcean Deployment Configuration
# Copy this file to .env and fill in your values

# ======================================
# DigitalOcean API (for creating new droplets)
# ======================================
DO_API_TOKEN=your_digitalocean_api_token

# ======================================
# Droplet Configuration
# ======================================
# For existing droplet: set DROPLET_IP
# For new droplet: leave DROPLET_IP empty
DROPLET_IP=

# SSH key fingerprint (from DigitalOcean > Settings > Security)
DO_SSH_KEY_FINGERPRINT=

# New droplet settings (only used if DROPLET_IP is empty)
DROPLET_NAME=portfolio
DROPLET_REGION=nyc1
# Recommended: s-2vcpu-4gb for running Elasticsearch + all services
# Minimum: s-1vcpu-2gb (may have memory pressure with Elasticsearch)
DROPLET_SIZE=s-2vcpu-4gb
DROPLET_IMAGE=ubuntu-24-04-x64

# ======================================
# Docker Registry (for local builds)
# ======================================
# Docker Hub username (run: docker login first)
DOCKER_USERNAME=

# Image names (will be prefixed with DOCKER_USERNAME/)
IMAGE_BACKEND=portfolio-backend
IMAGE_FRONTEND_FERNANDO=portfolio-frontend-fernando
IMAGE_FRONTEND_JESSICA=portfolio-frontend-jessica
IMAGE_FRONTEND_BUSYBEE=portfolio-frontend-busybee
IMAGE_FRONTEND_EXECUTIVE_CATERING=portfolio-frontend-executive-catering
IMAGE_FRONTEND_OPSBLUEPRINT=portfolio-frontend-opsblueprint
IMAGE_N8N_PYTHON_HELPER=portfolio-n8n-python-helper

# ======================================
# Application Configuration
# ======================================
# CMS Admin credentials (used for initial setup)
CMS_ADMIN_USERNAME=admin
CMS_ADMIN_PASSWORD=change_this_password

# JWT secret for authentication (generate a random 32+ char string)
JWT_SECRET_KEY=your_super_secret_key_at_least_32_characters_long

# ======================================
# Search & AI Configuration
# ======================================
# Elasticsearch URL (defaults to docker service name)
ELASTICSEARCH_URL=http://elasticsearch:9200

# Azure OpenAI for semantic search (optional - enables AI-powered search)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ======================================
# Azure OpenAI for Agent Chat
# ======================================
# Primary chat completion model (GPT-4o recommended)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# Model for tool calling / function calling
AZURE_OPENAI_TOOL_DEPLOYMENT=gpt-4o

# API version (use latest stable version)
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Optional: Secondary endpoint for failover
AZURE_OPENAI_ENDPOINT_SECONDARY=
AZURE_OPENAI_API_KEY_SECONDARY=

# Optional: Specific model configurations
AZURE_OPENAI_MAX_TOKENS=4096
AZURE_OPENAI_TEMPERATURE=0.7

# ======================================
# OpenAI-Compatible Fallback (Ollama, OpenRouter, LM Studio)
# ======================================
# Enable this as a fallback when Azure OpenAI is not configured
# Set OPENAI_COMPATIBLE_ENABLED=true to use local Ollama or other compatible APIs

# Enable/disable the fallback provider
OPENAI_COMPATIBLE_ENABLED=false

# Base URL for the OpenAI-compatible API
# Ollama: http://localhost:11434/v1 (or http://host.docker.internal:11434/v1 from Docker)
# OpenRouter: https://openrouter.ai/api/v1
# LM Studio: http://localhost:1234/v1
OPENAI_COMPATIBLE_BASE_URL=http://host.docker.internal:11434/v1

# API key (optional for local Ollama, required for OpenRouter)
OPENAI_COMPATIBLE_API_KEY=

# Default model to use
# Ollama: llama3.2, mistral, codellama, etc.
# OpenRouter: meta-llama/llama-3.2-3b-instruct, etc.
OPENAI_COMPATIBLE_MODEL=llama3.2

# ======================================
# Domain Configuration (Multi-Tenant)
# ======================================
# Each portfolio site can have its own domain
# Leave empty for localhost during development

# Fernando Vargas portfolio (main site with admin panel)
DOMAIN_FERNANDO=fernando-vargas.com

# Blog / Learning Lab subdomain
DOMAIN_BLOG=blog.fernando-vargas.com

# Jessica Sutherland portfolio (photographer)
DOMAIN_JESSICA=jessicasutherland.me

# Busy Bee portfolio (marketing agency)
DOMAIN_BUSYBEE=thebusybeeweb.com

# 1 Stop Wings
DOMAIN_1STOPWINGS=1stopwings.executivecateringct.com

# Executive Catering main site (demo subdomain under portfolio domain)
DOMAIN_EXECUTIVE_CATERING=executivecateringct.fernando-vargas.com

# OpsBlueprint (workflow automation consulting demo)
DOMAIN_OPSBLUEPRINT=opsblueprint.fernando-vargas.com

# ======================================
# Plausible Analytics (Self-Hosted)
# ======================================
# Domain where Plausible dashboard is accessible
DOMAIN_ANALYTICS=analytics.fernando-vargas.com

# Base URL must match the public URL (include https://)
PLAUSIBLE_BASE_URL=https://analytics.fernando-vargas.com

# Secret key base (at least 64 bytes, generate with: openssl rand -base64 48)
PLAUSIBLE_SECRET_KEY_BASE=

# Registration: true (open), false (closed), invite_only (admin invite only)
# Set to true for first deploy to create admin user, then change to invite_only
PLAUSIBLE_DISABLE_REGISTRATION=true

# ======================================
# Grafana Monitoring
# ======================================
# Domain where Grafana dashboard is accessible
DOMAIN_GRAFANA=grafana.fernando-vargas.com

# Grafana admin password (change this!)
GRAFANA_ADMIN_PASSWORD=

# ======================================
# n8n Workflow Automation
# ======================================
# Domain where n8n UI is accessible
DOMAIN_N8N=n8n.fernando-vargas.com

# Encryption key for n8n credentials storage (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=

# n8n basic auth credentials
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# n8n dedicated Postgres
N8N_POSTGRES_USER=n8n
N8N_POSTGRES_PASSWORD=
N8N_POSTGRES_DB=n8n

# ======================================
# Microsoft Graph (for n8n SharePoint + Outlook workflows)
# ======================================
# Azure AD App Registration (client_credentials flow)
# Create at: https://portal.azure.com > App Registrations
# Required API permissions (Application type, admin consented):
#   Mail.ReadWrite, Mail.Send, Files.ReadWrite.All, Sites.ReadWrite.All, User.Read.All
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# ======================================
# SharePoint Configuration (Executive Catering)
# ======================================
# Get site/drive IDs via Graph Explorer: https://developer.microsoft.com/graph/graph-explorer
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=

# Folder and file IDs (populated by running setup-catering-sharepoint.py)
SHAREPOINT_LEADS_FOLDER_ID=
SHAREPOINT_PROPOSALS_FOLDER_ID=
LEADS_TRACKER_FILE_ID=
EMAIL_CATEGORIES_FILE_ID=
EMAIL_CATEGORIES_TABLE_NAME=Categories

# Knowledge Base folder and file IDs (for AI-grounded proposals)
SHAREPOINT_KB_FOLDER_ID=
SHAREPOINT_KB_FILE_ID=

# ======================================
# Outlook Email (for n8n email workflows)
# ======================================
MAIL_USER_UPN=

