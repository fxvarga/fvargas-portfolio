# ── Production Caddyfile ─────────────────────────────────────
# Deploy to server: scp deploy/Caddyfile.production root@147.182.169.160:/opt/portfolio/Caddyfile
# Then restart:     ssh root@147.182.169.160 "cd /opt/portfolio && docker compose restart caddy"
#
# All domains use automatic Let's Encrypt TLS (no tls internal, no local_certs).
# Do NOT add blog.fernando-vargas.com — DNS does not exist for it.

# Fernando Vargas Portfolio
fernando-vargas.com, www.fernando-vargas.com {
    handle /graphql* {
        reverse_proxy backend:5000
    }
    handle /api/* {
        reverse_proxy backend:5000
    }
    handle /healthcheck {
        reverse_proxy backend:5000
    }
    handle {
        reverse_proxy frontend-fernando:80
    }
}

