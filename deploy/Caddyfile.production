# Brad Earnhardt Portfolio (static — no backend)
brad.fernando-vargas.com {
    handle {
        reverse_proxy frontend-brad:80
    }
}

# Plausible Analytics
analytics.fernando-vargas.com {
    reverse_proxy plausible:8000
}

# Grafana Monitoring
grafana.fernando-vargas.com {
    reverse_proxy grafana:3000
}

# n8n Workflow Automation
n8n.fernando-vargas.com {
    reverse_proxy n8n:5678 {
        header_up Connection {>Connection}
        header_up Upgrade {>Upgrade}
    }
}

# Discord Bot
bot.fernando-vargas.com {
    reverse_proxy discord-bot:3100
}

# TinyToes — Baby First Bites
tinytoes.fernando-vargas.com {
    handle /api/* {
        reverse_proxy tinytoes-api:8080
    }
    handle /healthz {
        reverse_proxy tinytoes-api:8080
    }
    handle {
        reverse_proxy tinytoes-web:80
    }
}
