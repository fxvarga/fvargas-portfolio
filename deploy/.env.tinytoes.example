# TinyToes environment variables
# Copy to .env.tinytoes and fill in values before deploying.

# ── Database ──
TINYTOES_DB_NAME=tinytoes
TINYTOES_DB_USER=tinytoes
TINYTOES_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Stripe ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Microsoft Graph (email delivery) ──
# Uses the same Azure AD app registration as the main portfolio.
# Required permission: Mail.Send (Application type, admin consented)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MAIL_USER_UPN=

# ── CORS / Cookies ──
TINYTOES_ALLOWED_ORIGINS=https://tinytoes.example.com
TINYTOES_COOKIE_DOMAIN=tinytoes.example.com

# ── Admin ──
TINYTOES_ADMIN_API_KEY=CHANGE_ME_RANDOM_API_KEY

# ── Caddy domain ──
DOMAIN_TINYTOES=tinytoes.example.com
