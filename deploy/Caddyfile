    # API and GraphQL routes to backend (CMS-powered content)
    handle /graphql* {
        reverse_proxy backend:5000
    }

    handle /api/* {
        reverse_proxy backend:5000
    }

    handle /uploads/* {
        reverse_proxy backend:5000
    }

    handle {
        reverse_proxy frontend-executive-catering:80
    }
}

