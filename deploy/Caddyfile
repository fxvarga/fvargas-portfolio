# ── TinyToes — Baby First Bites ──────────────────────────────

# TinyToes (HTTPS)
https://{$DOMAIN_TINYTOES:tinytoes.localhost} {
    tls internal

    # API routes → .NET backend
    handle /api/* {
        reverse_proxy tinytoes-api:8080
    }

    # Health check
    handle /healthz {
        reverse_proxy tinytoes-api:8080
    }

    # Everything else → SPA frontend
    handle {
        reverse_proxy tinytoes-web:80
    }
}

# TinyToes (LAN)
http://tinytoes.homehost {
    handle /api/* {
        reverse_proxy tinytoes-api:8080
    }

    handle /healthz {
        reverse_proxy tinytoes-api:8080
    }

    handle {
        reverse_proxy tinytoes-web:80
    }
}
