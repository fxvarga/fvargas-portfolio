# n8n Workflow Automation
n8n.fernando-vargas.com {
    reverse_proxy n8n:5678 {
        flush_interval -1
        transport http {
            keepalive 30s
        }
    }
}

# TinyToes Baby Tracker
tinytoes.fernando-vargas.com {
    reverse_proxy tinytoes-web:80
}

# Voice (Twingate-only). Public DNS resolves voice.fernando-vargas.com to the
# VM's private IP (10.20.1.4), so only Twingate-routed clients can reach it.
# Let's Encrypt HTTP-01 would fail (port 80 not public on that name), so we
# use DNS-01 via the GoDaddy plugin. GODADDY_API_TOKEN is "<key>:<secret>".
voice.fernando-vargas.com {
    tls {
        dns godaddy {env.GODADDY_API_TOKEN}
        propagation_delay 60s
        propagation_timeout 5m
    }
    reverse_proxy agentchat-web:80
}
