# Fernando Vargas Portfolio (main site + admin)
fernando-vargas.com {
    handle /graphql* {
        reverse_proxy backend:5000
    }
    handle /api/* {
        reverse_proxy backend:5000
    }
    handle /uploads/* {
        reverse_proxy backend:5000
    }
    handle /healthcheck {
        reverse_proxy backend:5000
    }
    handle {
        reverse_proxy frontend-fernando:80
    }
}

www.fernando-vargas.com {
    redir https://fernando-vargas.com{uri} permanent
}

